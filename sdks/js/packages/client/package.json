{
  "name": "@reactor/client",
  "version": "0.1.0",
  "description": "Reactor JS SDK - the official TypeScript client for Reactor",
  "keywords": ["reactor", "sdk", "typescript", "database", "auth", "storage", "functions", "jobs"],
  "license": "MIT",
  "author": "Reactor Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/reactor/reactor.git",
    "directory": "sdks/js/packages/client"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@reactor/shared": "workspace:*",
    "@reactor/analytics": "workspace:*",
    "@reactor/auth": "workspace:*",
    "@reactor/data": "workspace:*",
    "@reactor/storage": "workspace:*",
    "@reactor/functions": "workspace:*",
    "@reactor/jobs": "workspace:*",
    "@reactor/sites": "workspace:*",
    "@reactor/realtime": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
