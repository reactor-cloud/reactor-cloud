{
  "name": "@reactor/jobs-sdk",
  "version": "0.1.0",
  "description": "Reactor Jobs SDK - durable execution with step checkpointing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
